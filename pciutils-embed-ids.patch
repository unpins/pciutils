+
+/*
+ * unpins: embedded pci.ids fallback.
+ *
+ * The ID database is baked into the binary (embedded_pci_ids.h, generated by
+ * `xxd -i` at build time from hwdata's pci.ids) so `lspci` resolves vendor /
+ * device names with NO companion file on every OS -- a true single binary.
+ * A real on-disk database still takes precedence when present: the compiled
+ * default path, or one given with `lspci -i <file>` / pci_set_name_list_path()
+ * -- pci_open() tries that first and only falls back to the embedded copy when
+ * it cannot be opened.  This portable line reader (no fmemopen, which mingw
+ * lacks) wraps either a FILE* or the embedded byte buffer.
+ */
+#include "embedded_pci_ids.h"
+
+struct pci_id_stream {
+  FILE *fp;                     /* non-NULL: reading a real file        */
+  const unsigned char *buf;     /* else: reading the embedded database  */
+  size_t len;
+  size_t pos;
+};
+typedef struct pci_id_stream *pci_file;
+
+static pci_file pci_open(struct pci_access *a)
+{
+  struct pci_id_stream *s = malloc(sizeof(*s));
+  if (!s)
+    return NULL;
+  s->fp = fopen(a->id_file_name, "r");
+  if (s->fp)
+    {
+      s->buf = NULL;
+      s->len = s->pos = 0;
+      return s;
+    }
+  s->buf = embedded_pci_ids;
+  s->len = embedded_pci_ids_len;
+  s->pos = 0;
+  return s;
+}
+
+static char *pci_gets(pci_file s, char *line, int size)
+{
+  int i;
+  if (s->fp)
+    return fgets(line, size, s->fp);
+  if (s->pos >= s->len)
+    return NULL;
+  for (i = 0; i < size - 1 && s->pos < s->len; )
+    {
+      char c = (char) s->buf[s->pos++];
+      line[i++] = c;
+      if (c == '\n')
+	break;
+    }
+  line[i] = 0;
+  return line;
+}
+
+static int pci_eof(pci_file s)
+{
+  return s->fp ? feof(s->fp) : (s->pos >= s->len);
+}
+
+static void pci_close(pci_file s)
+{
+  if (s->fp)
+    fclose(s->fp);
+  free(s);
+}
+
+#define PCI_ERROR(f, err)	if (!err && (f)->fp && ferror((f)->fp)) err = "I/O error";
 #endif
 
